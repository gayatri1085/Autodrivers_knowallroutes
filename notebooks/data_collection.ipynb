 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# AutoRouteAI — Data Collection\n",
    "\n",
    "Demonstrates how to collect and prepare training data:\n",
    "\n",
    "1. Download OSM data for South Indian cities\n",
    "2. Fetch driver feedback from public sources\n",
    "3. Query Overpass API for road attributes\n",
    "4. Inspect road quality distributions\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import httpx\n",
    "import json\n",
    "import pandas as pd\n",
    "import geopandas as gpd\n",
    "from pathlib import Path\n",
    "\n",
    "DATA_DIR = Path('../data')\n",
    "print('Data dir:', DATA_DIR.resolve())"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Query Overpass API for road surface data in Chennai\n",
    "OVERPASS_URL = 'https://overpass-api.de/api/interpreter'\n",
    "\n",
    "query = '''\n",
    "[out:json][timeout:60];\n",
    "area[\"name\"=\"Chennai\"][\"admin_level\"=\"6\"]->.searchArea;\n",
    "(\n",
    "  way[\"highway\"][\"surface\"](area.searchArea);\n",
    ");\n",
    "out body;\n",
    "'''\n",
    "\n",
    "print('Querying Overpass API for Chennai road surfaces...')\n",
    "resp = httpx.post(OVERPASS_URL, data={'data': query}, timeout=90)\n",
    "data = resp.json()\n",
    "print(f'Found {len(data[\"elements\"])} roads with surface tags')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Analyse surface distribution\n",
    "surfaces = [el['tags'].get('surface', 'unknown') for el in data['elements'] if 'tags' in el]\n",
    "surface_df = pd.Series(surfaces).value_counts()\n",
    "print('Surface types in Chennai:')\n",
    "print(surface_df.head(10).to_string())"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Save to disk\n",
    "out_path = DATA_DIR / 'osm' / 'chennai_surfaces.json'\n",
    "out_path.parent.mkdir(parents=True, exist_ok=True)\n",
    "with open(out_path, 'w') as f:\n",
    "    json.dump(data, f)\n",
    "print(f'Saved to {out_path}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import sys\n",
    "sys.path.insert(0, '../backend')\n",
    "from routing.road_score import compute_road_score, SURFACE_SCORES\n",
    "\n",
    "# Compute scores for all surface types\n",
    "score_df = pd.DataFrame([\n",
    "    {'surface': s, 'road_score': compute_road_score(None, {'surface': s})}\n",
    "    for s in SURFACE_SCORES\n",
    "]).sort_values('road_score', ascending=False)\n",
    "\n",
    "print('Road scores by surface type:')\n",
    "print(score_df.to_string(index=False))"
   ]
  }
 ],
